# Configuration Proxmox API
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs

# URL de l'API Proxmox
PROXMOX_API_URL=https://192.168.68.200:8006/api2/json

# API Token (créé dans Proxmox: Datacenter → Permissions → API Tokens)
PROXMOX_TOKEN_ID=root@pam!terraform
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Node Proxmox cible
TARGET_NODE=proxmox

# Template LXC à utiliser
TEMPLATE_NAME=debian-12-standard_12.12-1_amd64.tar.zst

# Stockage pour les containers
VM_STORAGE=local-lvm

# Bridge réseau Proxmox (ID réseau / bridge)
VM_NETWORK_BRIDGE=vmbr0

# Clé SSH publique pour l'accès aux containers (optionnel)
# Laissez vide pour générer automatiquement une clé ED25519 par LXC
SSH_KEYS=""

# Credentials par défaut des containers (Cloud-init)
CI_USER=sio2027
CI_PASSWORD=Formation13@

# Configuration Windows (pour Active Directory)
# Nom du template Windows Server avec cloudbase-init
# Voir docs/windows-template-setup.md pour créer le template
WINDOWS_TEMPLATE_ID=WSERVER-TEMPLATE

# Mot de passe administrateur Windows
WINDOWS_ADMIN_PASSWORD=Admin123@

# Optionnel: mode auto "ISO -> template"
# Nom du fichier ISO Windows présent dans /var/lib/vz/template/iso/
WINDOWS_INSTALL_ISO=
# Nom du fichier ISO VirtIO (drivers) présent dans /var/lib/vz/template/iso/
VIRTIO_ISO=
# Storage Proxmox contenant les ISO (souvent "local")
WINDOWS_ISO_STORAGE=local
